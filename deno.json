{
  "name":    "xoropower-api",
  "version": "1.0.0",

  "tasks": {
    "dev":            "deno run --watch --allow-net --allow-env --allow-read main.ts",
    "start":          "deno run --allow-net --allow-env --allow-read main.ts",
    "test":           "deno test --allow-net --allow-env --allow-read --no-check tests/",
    "test:unit":      "deno test --allow-net --allow-env --allow-read --no-check tests/unit/",
    "test:integration": "deno test --allow-net --allow-env --allow-read --no-check tests/integration/",
    "test:e2e":       "deno test --allow-net --allow-env --allow-read --no-check tests/e2e/"
  },

  "imports": {
    "@oak/oak":      "jsr:@oak/oak@^13",
    "postgres":      "npm:postgres@^3",
    "bcryptjs":      "npm:bcryptjs@^2",
    "djwt":          "https://deno.land/x/djwt@v2.9/mod.ts",
    "zod":           "https://deno.land/x/zod@v3.24.1/mod.ts",
    "cors":          "https://deno.land/x/cors@v1.2.2/mod.ts",
    "dotenv":        "https://deno.land/std@0.224.0/dotenv/mod.ts",
    "@std/assert":   "jsr:@std/assert@^1",
    "@std/testing":  "jsr:@std/testing@^1"
  },

  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },

  "lint": {
    "rules": {
      "tags":    ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  }
}
