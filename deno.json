{
  "name":    "xoropower-api",
  "version": "1.0.0",

  "tasks": {
    "dev":   "deno run --watch --allow-net --allow-env --allow-read main.ts",
    "start": "deno run --allow-net --allow-env --allow-read main.ts"
  },

  "imports": {
    "@oak/oak":   "jsr:@oak/oak@^13",
    "postgres":   "npm:postgres@^3",
    "bcryptjs":   "npm:bcryptjs@^2",
    "djwt":       "https://deno.land/x/djwt@v2.9/mod.ts",
    "zod":        "https://deno.land/x/zod@v3.24.1/mod.ts",
    "cors":       "https://deno.land/x/cors@v1.2.2/mod.ts",
    "dotenv":     "https://deno.land/std@0.224.0/dotenv/mod.ts"
  },

  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },

  "lint": {
    "rules": {
      "tags":    ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  }
}
